# ── Database ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:change_me@localhost:5432/scheduler_db
POSTGRES_PASSWORD=change_me

# ── Worker ────────────────────────────────
WORKER_POLL_INTERVAL=3.0
MAX_RETRIES=3
CONCURRENCY_LIMIT=10

# ── Email Handler ─────────────────────────
EMAIL_FAILURE_RATE=0.0

# ── Starvation ────────────────────────────
STARVATION_THRESHOLD_SECONDS=900
STARVATION_CHECK_INTERVAL_SECONDS=60

# ── DLQ Alert ─────────────────────────────
DLQ_ALERT_THRESHOLD=10
ALERT_EMAIL=admin@dilamme.com
